{
  "expo": {
    "name": "CookNook",
    "slug": "CookNook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/App_Icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.mirajulislam.cooknook",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true
    },
    "android": {
      "package": "com.mirajulislam.cooknook",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFBEB",
        "foregroundImage": "./assets/App_Icon.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "ios": {
            "backgroundColor": "#FFFFFF"
          },
          "android": {
            "backgroundColor": "#FFFFFF",
            "drawable": {
              "icon": "./assets/blank-splash.xml"
            }
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.383657712113-gcq68k256o2op348s7khak74m4unbbnl"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload images for your recipes.",
          "cameraPermission": "The app accesses your camera to let you take photos of your recipes."
        }
      ],
      "expo-video",
      "react-native-compressor"
    ]
  }
}
